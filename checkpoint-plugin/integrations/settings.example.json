{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m checkpoint_plugin.integrations.claude_code_hook session_start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m checkpoint_plugin.integrations.claude_code_hook turn_end"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m checkpoint_plugin.integrations.claude_code_hook subagent_end"
          }
        ]
      }
    ]
  }
}
