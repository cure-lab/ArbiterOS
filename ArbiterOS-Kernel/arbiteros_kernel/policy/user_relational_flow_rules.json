{
  "evaluation_mode": "first_match",
  "source": "user_relational_flow_rules.json",
  "description": "User-authored relational flow policy rules compiled from Policy Rule IR with declared metadata contracts.",
  "rules": [
    {
      "id": "USER-FLOW-HIGH-CONF-OUTBOUND-001",
      "enabled": false,
      "title": "block high confidentiality outbound flow",
      "description": "block high-confidentiality source context from flowing to communication, delegation, voice, or direct response sinks",
      "scope": "relational",
      "source_selector": {},
      "selector": {
        "flow_kind": [
          "comm_sink",
          "delegate_sink",
          "voice_sink",
          "respond_sink"
        ]
      },
      "predicate": {
        "ge": [
          {
            "var": "source_confidentiality"
          },
          {
            "const": "HIGH"
          }
        ]
      },
      "effect": "BLOCK",
      "message": "高敏感上下文不允许直接流向对外可见或跨会话目标。",
      "source": "policy_rule_ir",
      "severity": "HIGH"
    },
    {
      "id": "USER-FLOW-LOW-TRUST-SIDE-EFFECT-001",
      "enabled": true,
      "title": "block low trust source driving side effects",
      "description": "block side-effecting actions when the source context is lower than UNKNOWN trustworthiness",
      "scope": "relational",
      "source_selector": {},
      "selector": {
        "flow_kind": [
          "exec_side_effect",
          "ui_side_effect"
        ]
      },
      "predicate": {
        "all": [
          {
            "lt": [
              {
                "var": "source_trustworthiness"
              },
              {
                "const": "UNKNOWN"
              }
            ]
          },
          {
            "not": {
              "truthy": {
                "var": "calendar_ui_action"
              }
            }
          }
        ]
      },
      "effect": "BLOCK",
      "message": "低可信来源不能直接驱动执行、界面控制或持久化副作用。",
      "source": "policy_rule_ir",
      "severity": "HIGH"
    },
    {
      "id": "USER-FLOW-PII-EXTERNAL-MESSAGE-001",
      "enabled": true,
      "title": "block PII labels to external message domains",
      "description": "block outbound message when source labels contain PII and the sink has external recipient domains",
      "scope": "relational",
      "source_selector": {},
      "selector": {
        "tool": [
          "message",
          "gmail__send_email",
          "gmail__send_reply",
          "gmail__forward_message",
          "slack__post_message",
          "telegram__send_message"
        ],
        "flow_kind": [
          "comm_sink"
        ]
      },
      "predicate": {
        "all": [
          {
            "exists": {
              "var": "external_recipient_domains"
            }
          },
          {
            "exists": {
              "var": "source_data_labels"
            }
          },
          {
            "all": [
              {
                "intersects": [
                  {
                    "var": "source_data_labels"
                  },
                  {
                    "const": [
                      "PII",
                      "SECRET"
                    ]
                  }
                ]
              },
              {
                "gt": [
                  {
                    "len": {
                      "var": "external_recipient_domains"
                    }
                  },
                  {
                    "const": 0
                  }
                ]
              }
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "包含 PII 标签的上下文不能发送到外部消息域。",
      "source": "policy_rule_ir",
      "severity": "CRITICAL"
    },
    {
      "id": "USER-FLOW-DIRECT-PII-EXTERNAL-MESSAGE-001",
      "enabled": true,
      "title": "block direct PII in outbound message arguments",
      "description": "block outbound messages when the current message arguments directly contain PII-like content and the recipient is external",
      "scope": "relational",
      "source_selector": {},
      "selector": {
        "tool": [
          "message",
          "gmail__send_email",
          "gmail__send_reply",
          "gmail__forward_message",
          "slack__post_message",
          "telegram__send_message"
        ],
        "flow_kind": [
          "comm_sink"
        ]
      },
      "predicate": {
        "all": [
          {
            "gt": [
              {
                "len": {
                  "var": "external_recipient_domains"
                }
              },
              {
                "const": 0
              }
            ]
          },
          {
            "truthy": {
              "var": "outbound_message_contains_pii"
            }
          },
          {
            "not": {
              "all": [
                {
                  "truthy": {
                    "var": "outbound_message_contains_financial_or_payment"
                  }
                },
                {
                  "any": [
                    {
                      "var": "prior_payment_state_change"
                    },
                    {
                      "var": "current_payment_state_change"
                    },
                    {
                      "var": "prior_opportunity_state_change"
                    },
                    {
                      "var": "current_opportunity_state_change"
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      "effect": "BLOCK",
      "message": "当前外发消息正文直接包含邮箱、电话等疑似 PII，且接收方属于外部域，已暂停发送。",
      "source": "policy_rule_ir",
      "severity": "CRITICAL"
    },
