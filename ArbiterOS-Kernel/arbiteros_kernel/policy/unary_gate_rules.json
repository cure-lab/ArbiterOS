{
  "evaluation_mode": "first_match",
  "source": "unary_gate_rules.json",
  "rules": [
    {
      "id": "UG-001",
      "title": "missing instruction metadata",
      "description": "tool call must have kernel-lowered instruction metadata",
      "scope": "tool",
      "selector": {},
      "predicate": {
        "truthy": {
          "var": "missing_instruction"
        }
      },
      "effect": "BLOCK",
      "message": "当前 tool_call 没有找到对应的 instruction metadata，策略无法安全判定。"
    },
    {
      "id": "UG-010",
      "title": "argument string budget",
      "description": "block tool call when total argument string length exceeds 4000",
      "scope": "tool",
      "selector": {},
      "predicate": {
        "gt": [
          {
            "var": "arg_total_str_len"
          },
          {
            "const": 4000
          }
        ]
      },
      "effect": "BLOCK",
      "message": "tool arguments are too large."
    },
    {
      "id": "UG-020",
      "title": "exec confidence gate",
      "description": "EXEC requires confidence >= MID",
      "scope": "tool",
      "selector": {
        "instruction_type": [
          "EXEC"
        ]
      },
      "predicate": {
        "lt": [
          {
            "var": "confidence"
          },
          {
            "const": "MID"
          }
        ]
      },
      "effect": "BLOCK",
      "message": "EXEC requires confidence >= MID."
    },
    {
      "id": "UG-021",
      "title": "exec trust gate",
      "description": "EXEC requires trustworthiness >= MID",
      "scope": "tool",
      "selector": {
        "instruction_type": [
          "EXEC"
        ]
      },
      "predicate": {
        "lt": [
          {
            "var": "trustworthiness"
          },
          {
            "const": "MID"
          }
        ]
      },
      "effect": "BLOCK",
      "message": "EXEC requires trustworthiness >= MID."
    },
    {
      "id": "UG-030",
      "title": "high risk exec",
      "description": "exec with HIGH or CRITICAL risk is blocked",
      "scope": "tool",
      "selector": {
        "tool": [
          "exec"
        ]
      },
      "predicate": {
        "in": [
          {
            "var": "risk"
          },
          {
            "const": [
              "HIGH",
              "CRITICAL"
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "高风险 exec 不允许直接执行。"
    },
    {
      "id": "UG-031",
      "title": "approval required block",
      "description": "actions explicitly marked approval_required are blocked here",
      "scope": "tool",
      "selector": {
        "tool": [
          "exec",
          "write"
        ]
      },
      "predicate": {
        "truthy": {
          "var": "approval_required"
        }
      },
      "effect": "BLOCK",
      "message": "kernel metadata marks this action as approval_required."
    },
    {
      "id": "UG-032",
      "title": "destructive must be reversible",
      "description": "destructive action must be reversible",
      "scope": "tool",
      "selector": {
        "tool": [
          "exec",
          "write"
        ]
      },
      "predicate": {
        "all": [
          {
            "truthy": {
              "var": "destructive"
            }
          },
          {
            "falsy": {
              "var": "reversible"
            }
          }
        ]
      },
      "effect": "BLOCK",
      "message": "破坏性操作必须满足 reversible=true。"
    },
    {
      "id": "UG-040",
      "title": "blocked secret like tags",
      "description": "block actions tagged SECRET_LIKE or HIGH_RISK",
      "scope": "tool",
      "selector": {},
      "predicate": {
        "intersects": [
          {
            "var": "tags"
          },
          {
            "const": [
              "SECRET_LIKE",
              "HIGH_RISK"
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "blocked tag hit."
    },

    {
      "id": "UG-060",
      "title": "protected identity or control file direct mutation",
      "description": "block direct write or edit to protected identity/control files",
      "scope": "tool",
      "selector": {
        "tool": [
          "write",
          "edit"
        ]
      },
      "predicate": {
        "intersects": [
          {
            "var": "direct_target_basenames"
          },
          {
            "const": [
              "SOUL.MD",
              "AGENTS.MD",
              "IDENTITY.MD"
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "protected identity/control files cannot be directly modified."
    },
    {
      "id": "UG-061",
      "title": "protected identity or control file exec write target",
      "description": "block exec or process writes targeting protected identity/control files",
      "scope": "tool",
      "selector": {
        "tool": [
          "exec",
          "process"
        ]
      },
      "predicate": {
        "intersects": [
          {
            "var": "exec_write_target_basenames"
          },
          {
            "const": [
              "SOUL.MD",
              "AGENTS.MD",
              "IDENTITY.MD"
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "exec or process may not write protected identity/control files."
    },
    {
      "id": "UG-062",
      "title": "protected identity or control file mutation instruction",
      "description": "block outbound or delegated content that explicitly instructs mutation of protected identity/control files",
      "scope": "tool",
      "selector": {
        "tool": [
          "message",
          "sessions_send",
          "sessions_spawn"
        ]
      },
      "predicate": {
        "all": [
          {
            "any": [
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "SOUL.MD"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "AGENTS.MD"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "IDENTITY.MD"
                  }
                ]
              }
            ]
          },
          {
            "any": [
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "WRITE"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "EDIT"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "MODIFY"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "PATCH"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "REPLACE"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "OVERRIDE"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "INJECT"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "APPEND"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "DELETE"
                  }
                ]
              }
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "outbound or delegated content must not instruct mutation of protected identity/control files."
    },
    {
      "id": "UG-070",
      "title": "suspicious gateway external redirection patch",
      "description": "block gateway config patch or apply that introduces external proxy or upstream redirection",
      "scope": "tool",
      "selector": {
        "tool": [
          "gateway"
        ]
      },
      "predicate": {
        "all": [
          {
            "in": [
              {
                "var": "action"
              },
              {
                "const": [
                  "CONFIG.PATCH",
                  "CONFIG.APPLY"
                ]
              }
            ]
          },
          {
            "truthy": {
              "var": "has_external_url"
            }
          },
          {
            "any": [
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "PROXY"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "UPSTREAM"
                  }
                ]
              },
              {
                "contains": [
                  {
                    "var": "arg_text_upper"
                  },
                  {
                    "const": "BASE_URL"
                  }
                ]
              }
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "gateway config patch or apply must not introduce external proxy or upstream redirection without stronger review."
    },

    {
      "id": "UG-050",
      "title": "respond prop confidentiality",
      "description": "RESPOND must keep propagated confidentiality <= MID",
      "scope": "respond",
      "selector": {
        "instruction_type": [
          "RESPOND"
        ]
      },
      "predicate": {
        "gt": [
          {
            "var": "prop_confidentiality"
          },
          {
            "const": "MID"
          }
        ]
      },
      "effect": "BLOCK",
      "message": "当前响应的传播保密级别过高。"
    }
  ]
}