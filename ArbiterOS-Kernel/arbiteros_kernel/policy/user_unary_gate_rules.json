{
  "evaluation_mode": "first_match",
  "source": "user_unary_gate_rules.json",
  "description": "User-authored unary tool-call policy rules compiled from Policy Rule IR with declared metadata contracts.",
  "rules": [
    {
      "id": "USER-AI-TRADER-NOTIONAL-001",
      "enabled": true,
      "title": "block large ai trader notional",
      "description": "block AI-Trader realtime trades whose notional value is greater than 5000",
      "scope": "tool",
      "selector": {
        "tool": [
          "trade"
        ]
      },
      "predicate": {
        "all": [
          {
            "exists": {
              "var": "ai_trader_notional"
            }
          },
          {
            "gt": [
              {
                "var": "ai_trader_notional"
              },
              {
                "const": 5000
              }
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "AI-Trader 单笔交易名义金额超过 5000，已拦截。",
      "source": "policy_rule_ir",
      "severity": "HIGH"
    },
    {
      "id": "USER-AI-TRADER-SHORT-001",
      "enabled": true,
      "title": "block ai trader short actions",
      "description": "block AI-Trader short actions unless a user explicitly changes this rule",
      "scope": "tool",
      "selector": {
        "tool": [
          "trade"
        ]
      },
      "predicate": {
        "any": [
          {
            "missing": {
              "var": "ai_trader_is_short"
            }
          },
          {
            "truthy": {
              "var": "ai_trader_is_short"
            }
          }
        ]
      },
      "effect": "BLOCK",
      "message": "当前策略不允许发布做空交易信号。",
      "source": "policy_rule_ir",
      "severity": "HIGH"
    },
    {
      "id": "USER-AI-TRADER-POLYMARKET-OUTCOME-001",
      "enabled": true,
      "title": "require polymarket outcome context",
      "description": "block Polymarket trades when both outcome and token_id are missing",
      "scope": "tool",
      "selector": {
        "tool": [
          "trade"
        ]
      },
      "predicate": {
        "all": [
          {
            "exists": {
              "var": "ai_trader_has_outcome"
            }
          },
          {
            "exists": {
              "var": "ai_trader_has_token_id"
            }
          },
          {
            "exists": {
              "var": "ai_trader_is_polymarket"
            }
          },
          {
            "all": [
              {
                "truthy": {
                  "var": "ai_trader_is_polymarket"
                }
              },
              {
                "falsy": {
                  "var": "ai_trader_has_outcome"
                }
              },
              {
                "falsy": {
                  "var": "ai_trader_has_token_id"
                }
              }
            ]
          }
        ]
      },
      "effect": "BLOCK",
      "message": "Polymarket 交易缺少 outcome 或 token_id，已拦截。",
      "source": "policy_rule_ir",
      "severity": "MEDIUM"
    }
  ],
  "required_metadata": [
    {
      "field": "ai_trader_notional",
      "type": "number",
      "description": "Absolute trade notional computed as price * quantity.",
      "applies_to": {
        "tools": [
          "trade"
        ]
      },
      "source": {
        "kind": "tool_arguments",
        "paths": [
          "notional"
        ],
        "transform": "abs_number",
        "operands": [
          "price",
          "quantity"
        ]
      },
      "normalization": "Use absolute numeric price * quantity. Price 0 means platform simulated pricing and may produce 0 notional before execution.",
      "on_missing": "no_match",
      "required_for_rules": [
        "USER-AI-TRADER-NOTIONAL-001"
      ]
    },
    {
      "field": "ai_trader_is_short",
      "type": "boolean",
      "description": "True when the AI-Trader action is short.",
      "applies_to": {
        "tools": [
          "trade"
        ]
      },
      "source": {
        "kind": "tool_arguments",
        "paths": [
          "action",
          "side",
          "position"
        ],
        "transform": "equals",
        "value": "short"
      },
      "normalization": "action lowercased equals short.",
      "on_missing": "fail_closed",
      "required_for_rules": [
        "USER-AI-TRADER-SHORT-001"
      ]
    },
    {
      "field": "ai_trader_is_polymarket",
      "type": "boolean",
      "description": "True when market is polymarket.",
      "applies_to": {
        "tools": [
          "trade"
        ]
      },
      "source": {
        "kind": "tool_arguments",
        "paths": [
          "market",
          "platform",
          "exchange",
          "venue"
        ],
        "transform": "equals",
        "value": "polymarket"
      },
      "normalization": "market lowercased equals polymarket.",
      "on_missing": "no_match",
      "required_for_rules": [
        "USER-AI-TRADER-POLYMARKET-OUTCOME-001"
      ]
    },
    {
      "field": "ai_trader_has_outcome",
      "type": "boolean",
      "description": "True when a non-empty Polymarket outcome is present.",
      "applies_to": {
        "tools": [
          "trade"
        ]
      },
      "source": {
        "kind": "tool_arguments",
        "paths": [
          "outcome"
        ],
        "transform": "nonempty"
      },
      "normalization": "outcome is a non-empty string.",
      "on_missing": "no_match",
      "required_for_rules": [
        "USER-AI-TRADER-POLYMARKET-OUTCOME-001"
      ]
    },
    {
      "field": "ai_trader_has_token_id",
      "type": "boolean",
      "description": "True when a non-empty Polymarket token_id is present.",
      "applies_to": {
        "tools": [
          "trade"
        ]
      },
      "source": {
        "kind": "tool_arguments",
        "paths": [
          "token_id",
          "tokenId",
          "token.id"
        ],
        "transform": "nonempty"
      },
      "normalization": "token_id is a non-empty string.",
      "on_missing": "no_match",
      "required_for_rules": [
        "USER-AI-TRADER-POLYMARKET-OUTCOME-001"
      ]
    }
  ]
}
